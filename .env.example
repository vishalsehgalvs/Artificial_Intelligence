# .env.example — Copy this file to .env and fill in your actual API keys
# -----------------------------------------------------------------------
# NEVER commit your real .env file to GitHub — it's in .gitignore
#
# How to get each key:
#   GOOGLE_API_KEY    → https://aistudio.google.com → Get API key (FREE)
#   MISTRAL_API_KEY   → https://console.mistral.ai   (FREE tier available)
#   GROQ_API_KEY      → https://console.groq.com     (FREE tier available)
#   OPENAI_API_KEY    → https://platform.openai.com  (PAID — pay as you go)
#   HUGGINGFACEHUB_API_TOKEN → https://huggingface.co/settings/tokens (FREE)

GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# For LangSmith tracing (optional — helps debug LangChain apps)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
